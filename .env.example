# === Database (use pooled connection on Vercel) ===
DATABASE_URL=postgresql://USER:PASSWORD@POOL_HOST:POOL_PORT/DBNAME
# Optional read replica (also pooled). If unset, reads use DATABASE_URL.
READ_DATABASE_URL=

# === Supabase ===
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_CSV_BUCKET=ingestion

# === Appwrite (Auth) ===
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=
APPWRITE_API_KEY=
APPWRITE_DB_ID=b2b
APPWRITE_USERPROFILES_COL=user_profiles
APPWRITE_VENDORS_COL=vendors

# === CORS ===
# List of allowed origins for browsers (comma separated).
CORS_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app
# Set to 1 to allow any origin (avoid in production).
CORS_ALLOW_ALL=

# === Cron tick protection ===
# If set, /api/queue-tick requires ?secret=<value> or header X-Queue-Secret:<value>
QUEUE_TICK_SECRET=

# === Branding (public, for login/register pages) ===
# Vendor display name (e.g. "Sam's Club"). Frontend fetches from backend.
VENDOR_NAME=
# Footer copyright (e.g. "© 2024 Sam's West, Inc. All rights reserved.")
VENDOR_COPYRIGHT=

# === B2B feature flags (gold unification phase) ===
B2B_ENABLE_JOBS=0
B2B_ENABLE_MATCHING=0
START_QUEUE=0

# === RAG API (PRD-01 - optional, all flags OFF by default) ===
RAG_API_URL=http://rag-api:8000
RAG_API_KEY=

# Per-feature flags (all OFF - existing SQL workflow unchanged)
USE_GRAPH_RECOMMEND=false
USE_GRAPH_SEARCH=false
USE_GRAPH_MATCH=false
USE_GRAPH_CHATBOT=false
USE_GRAPH_ANALYTICS=false
USE_GRAPH_SAFETY=false
USE_GRAPH_INTEL=false
USE_GRAPH_SUBSTITUTE=false
